"```json\n[\n  {\n    \"key\": \"name\",\n    \"value\": \"半夏泻心汤\",\n    \"text_value\": \"半夏泻心汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"半夏12克（洗），黄芩 干姜 人参 甘草（炙）各9克， 黄连3克， 大枣12枚（擘）\",\n    \"text_value\": \"半夏（半升洗） 黄芩 干姜 人参 甘草（各三两炙） 黄连（一两） 大枣（十二枚）上七味。\",\n    \"components\": [\n      {\n        \"text_name\": \"半夏\",\n        \"text_count\": \"半升（洗）\"\n      },\n      {\n        \"text_name\": \"黄芩\",\n        \"text_count\": \"三两（炙）（各三两炙）\"\n      },\n      {\n        \"text_name\": \"干姜\",\n        \"text_count\": \"三两（炙）（各三两炙）\"\n      },\n      {\n        \"text_name\": \"人参\",\n        \"text_count\": \"三两（炙）（各三两炙）\"\n      },\n      {\n        \"text_name\": \"甘草\",\n        \"text_count\": \"三两（炙）（各三两炙）\"\n      },\n      {\n        \"text_name\": \"黄连\",\n        \"text_count\": \"一两\"\n      },\n      {\n        \"text_name\": \"大枣\",\n        \"text_count\": \"十二枚\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"和胃降逆，散结消痞。主寒热中阻，胃气不和，心下痞满不痛，或干呕，或呕吐，肠鸣下利，舌苔薄黄而腻，脉弦数者。\",\n    \"text_value\": \"但治其中。而上呕下鸣之证俱愈也。\"\n  }\n]\n```"