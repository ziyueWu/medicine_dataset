"```json\n[\n  {\n    \"key\": \"name\",\n    \"value\": \"大柴胡汤\",\n    \"text_value\": \"大柴胡汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"柴胡12g　黄芩9g　芍药9g　半夏9g　生姜15g　枳实9g　大枣4枚　大黄6g \",\n    \"text_value\": \"柴胡（半斤） 黄芩（三两） 半夏（半斤洗） 芍药（三两） 枳实（四枚炙） 大黄（二两）生姜（五两切） 大枣（十二枚擘）上七味。\",\n    \"components\": [\n      {\n        \"text_name\": \"柴胡\",\n        \"text_count\": \"半斤\"\n      },\n      {\n        \"text_name\": \"黄芩\",\n        \"text_count\": \"三两\"\n      },\n      {\n        \"text_name\": \"半夏\",\n        \"text_count\": \"半斤\"\n      },\n      {\n        \"text_name\": \"芍药\",\n        \"text_count\": \"三两\"\n      },\n      {\n        \"text_name\": \"枳实\",\n        \"text_count\": \"四枚\"\n      },\n      {\n        \"text_name\": \"大黄\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"生姜\",\n        \"text_count\": \"五两\"\n      },\n      {\n        \"text_name\": \"大枣\",\n        \"text_count\": \"十二枚\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"少阳阳明合病。往来寒热，胸胁苦满，呕不止，郁郁微烦，心下痞硬，或心下满痛，大便不解或下利，舌苔黄，脉弦数有力。\",\n    \"text_value\": \"少阳阳明合病。往来寒热，胸胁苦满，呕不止，郁郁微烦，心下痞硬，或心下满痛，大便不解或下利，舌苔黄，脉弦数有力。\"\n  }\n]\n```"