"[\n  {\n    \"key\": \"name\",\n    \"value\": \"石膏汤\",\n    \"text_value\": \"石膏汤方\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"石膏30克 黄连 黄柏 黄芩各6克 香豉9克(绵裹) 栀子9克(擘) 麻黄9克(去节)。\",\n    \"text_value\": \"石膏汤方石膏 黄连 黄柏 黄芩（各二两）香豉（一升绵裹）栀子（十枚擘） 麻黄（三两去节）上七味。\",\n    \"components\": [\n      {\n        \"text_name\": \"石膏\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"黄连\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"黄柏\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"黄芩\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"香豉\",\n        \"text_count\": \"一升\"\n      },\n      {\n        \"text_name\": \"栀子\",\n        \"text_count\": \"十枚\"\n      },\n      {\n        \"text_name\": \"麻黄\",\n        \"text_count\": \"三两\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"伤寒表证未解，里热炽盛，故解表与清里兼顾。\",\n    \"text_value\": \"而方无表里。疗者意思以三黄汤以救其内。有所增加以解其外。\"\n  }\n]"