"[\n  {\n    \"key\": \"name\",\n    \"value\": \"茯苓丸\",\n    \"text_value\": \"茯苓丸\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"茯苓6g  枳壳3g  半夏9g  风化硝3g\",\n    \"text_value\": \"半夏燥湿。茯苓渗湿。风硝软坚。枳壳利气。\",\n    \"components\": [\n      {\n        \"text_name\": \"茯苓\",\n        \"text_count\": \"6g\"\n      },\n      {\n        \"text_name\": \"枳壳\",\n        \"text_count\": \"3g\"\n      },\n      {\n        \"text_name\": \"半夏\",\n        \"text_count\": \"9g\"\n      },\n      {\n        \"text_name\": \"风化硝\",\n        \"text_count\": \"3g\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"痰停中脘证。两臂疼痛，手不得上举，或左右时复转移，或两手疲软，或四肢浮肿，舌苔白腻，脉沉细或弦滑等。\",\n    \"text_value\": \"降气燥湿是治其标。温肾利水是治其本也。此方欲兼两者而合治之。\"\n  }\n]"