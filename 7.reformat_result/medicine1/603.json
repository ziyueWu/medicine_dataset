"```json\n[\n  {\n    \"key\": \"name\",\n    \"value\": \"真武汤\",\n    \"text_value\": \"真武汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"茯苓9克 芍药9克 白术6克 生姜（切）9克 附子5克（炮）\",\n    \"text_value\": \"茯苓三两、芍药三两、生姜三两（切）、白术二两、附子一枚（炮，去皮，破八片）\",\n    \"components\": [\n      {\n        \"text_name\": \"茯苓\",\n        \"text_count\": \"三两\"\n      },\n      {\n        \"text_name\": \"芍药\",\n        \"text_count\": \"三两\"\n      },\n      {\n        \"text_name\": \"生姜（切）\",\n        \"text_count\": \"三两\"\n      },\n      {\n        \"text_name\": \"白术\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"附子（炮，去皮，破八片）\",\n        \"text_count\": \"一枚\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"脾肾阳衰，水气内停，小便不利，四肢沉重疼痛，腹痛下利，或肢体浮肿，苔白不渴，太阳病发汗，汗出不解，其人仍发热，心下悸，头眩，身瞤动，振振欲擗地者。现用于肝、肾性水肿，心性水肿，耳源性眩晕，慢性结肠炎等属于牌肾阳虚者。\",\n    \"text_value\": \"主治恶寒体痛，四肢沉重，身体（膶）动，摇摇欲倒，脉沉小；头眩，小便不利，心悸，下肢浮肿等；适用于少阴病阳气不足、阴邪有余，水饮内结，寒湿疼痛等症候。\"\n  }\n]\n```"