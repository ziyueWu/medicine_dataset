"[\n  {\n    \"key\": \"name\",\n    \"value\": \"清脾饮\",\n    \"text_value\": \"清脾饮\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"白术1钱，茯苓1钱，知母1钱，青皮4分，厚朴8分，黄芩2钱，甘草5分，柴胡，生姜。\",\n    \"text_value\": \"青皮、浓朴（醋炒）、柴胡、黄芩、半夏（姜制）、甘草（炙）、茯苓、白术（土炒）、草果（煨），加姜煎。疟不止，加酒炒常山一钱，乌梅二个；大渴，加麦冬、知母。\",\n    \"components\": [\n      {\n        \"text_name\": \"青皮\",\n        \"text_count\": \"4分\"\n      },\n      {\n        \"text_name\": \"浓朴（醋炒）\",\n        \"text_count\": \"8分\"\n      },\n      {\n        \"text_name\": \"柴胡\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"黄芩\",\n        \"text_count\": \"2钱\"\n      },\n      {\n        \"text_name\": \"半夏（姜制）\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"甘草（炙）\",\n        \"text_count\": \"5分\"\n      },\n      {\n        \"text_name\": \"茯苓\",\n        \"text_count\": \"1钱\"\n      },\n      {\n        \"text_name\": \"白术（土炒）\",\n        \"text_count\": \"1钱\"\n      },\n      {\n        \"text_name\": \"草果（煨）\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"生姜\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"常山（酒炒）\",\n        \"text_count\": \"一钱\"\n      },\n      {\n        \"text_name\": \"乌梅\",\n        \"text_count\": \"二个\"\n      },\n      {\n        \"text_name\": \"麦冬\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"知母\",\n        \"text_count\": \"1钱\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"妊娠疟症，热多寒少。\",\n    \"text_value\": \"热多阳疟此方佳。\"\n  }\n]"