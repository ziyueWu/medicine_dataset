"```json\n[\n  {\n    \"key\": \"name\",\n    \"value\": \"当归生姜羊肉汤\",\n    \"text_value\": \"当归生姜羊肉汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"当归9克 生姜15克 羊肉50克\",\n    \"text_value\": \"当归三两(9克) 生姜五两(15克) 羊肉二斤(50克)\",\n    \"components\": [\n      {\n        \"text_name\": \"当归\",\n        \"text_count\": \"9克\"\n      },\n      {\n        \"text_name\": \"生姜\",\n        \"text_count\": \"15克\"\n      },\n      {\n        \"text_name\": \"羊肉\",\n        \"text_count\": \"50克\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"温中养血，祛寒止痛。用于寒疝，虚劳，产后血虚有寒，腹痛，胁痛，喜温喜按，腹中拘急，苔白，脉沉弦而涩。\",\n    \"text_value\": \"寒疝腹中痛，及胁痛里急者，当归生姜羊肉汤主之；产后腹中(疗)痛，当归生姜羊肉汤主之；并治腹中寒疝，虚劳不足；主治血虚有寒之腹痛证候，如产后腹痛、寒疝腹痛。\"\n  }\n]\n```"