"[\n  {\n    \"key\": \"name\",\n    \"value\": \"五皮饮\",\n    \"text_value\": \"（澹寮）用五般皮\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"陈皮9克、茯苓皮24克、生姜皮6克、桑白皮9克、大腹皮9克。\",\n    \"text_value\": \"（陈皮、茯苓皮、姜皮、桑白皮、大腹皮）\",\n    \"components\": [\n      {\n        \"text_name\": \"陈皮\",\n        \"text_count\": \"9克\"\n      },\n      {\n        \"text_name\": \"茯苓皮\",\n        \"text_count\": \"24克\"\n      },\n      {\n        \"text_name\": \"生姜皮\",\n        \"text_count\": \"6克\"\n      },\n      {\n        \"text_name\": \"桑白皮\",\n        \"text_count\": \"9克\"\n      },\n      {\n        \"text_name\": \"大腹皮\",\n        \"text_count\": \"9克\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"用于全身水肿，胸腹胀满，小便不利以及妊娠水肿等。本方也常用于各种原因引起的水肿，但以急性肾炎水肿、妊娠水肿、经期水肿以及腹水等较为多用。\",\n    \"text_value\": \"（脾不能为胃行其津液，故水肿。半身以上，宜汗；半身以下，宜利小便。）\"\n  }\n]"