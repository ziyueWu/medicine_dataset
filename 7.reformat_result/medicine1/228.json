"[\n  {\n    \"key\": \"name\",\n    \"value\": \"回阳救急汤\",\n    \"text_value\": \"回阳急救\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"熟附子9克，干姜6克，人参6克，炙甘草6克，炒白术9克，肉桂3克，陈皮6克，五味子3克，茯苓9克，制半夏9克。\",\n    \"text_value\": \"附子炮、干姜、肉桂、人参各五分；白术、茯苓各一钱；半夏、陈皮各七分；甘草三分；五味九粒（姜水煎）。（）加麝三厘或胆汁。\",\n    \"components\": [\n      {\n        \"text_name\": \"附子（炮）\",\n        \"text_count\": \"五分\"\n      },\n      {\n        \"text_name\": \"干姜\",\n        \"text_count\": \"五分\"\n      },\n      {\n        \"text_name\": \"肉桂\",\n        \"text_count\": \"五分\"\n      },\n      {\n        \"text_name\": \"人参\",\n        \"text_count\": \"五分\"\n      },\n      {\n        \"text_name\": \"白术\",\n        \"text_count\": \"一钱\"\n      },\n      {\n        \"text_name\": \"茯苓\",\n        \"text_count\": \"一钱\"\n      },\n      {\n        \"text_name\": \"半夏\",\n        \"text_count\": \"七分\"\n      },\n      {\n        \"text_name\": \"陈皮\",\n        \"text_count\": \"七分\"\n      },\n      {\n        \"text_name\": \"甘草\",\n        \"text_count\": \"三分\"\n      },\n      {\n        \"text_name\": \"五味\",\n        \"text_count\": \"九粒\"\n      },\n      {\n        \"text_name\": \"麝\",\n        \"text_count\": \"三厘\"\n      },\n      {\n        \"text_name\": \"胆汁\",\n        \"text_count\": \"（或加，未给定剂量）\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"寒邪直中三阴，真阳衰微证。四肢厥冷，神衰欲寐，恶寒蜷卧，吐泻腹痛，口不渴，甚则身寒战栗，或指甲口唇青紫，或吐涎沫，舌淡苔白，脉沉微，甚或无脉。 本方常用于急性胃肠炎吐泻过多、休克、心力衰竭等属亡阳欲脱者。\",\n    \"text_value\": \"回阳急救（节庵）。\"\n  }\n]"