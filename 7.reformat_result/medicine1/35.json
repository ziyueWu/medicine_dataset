"[\n  {\n    \"key\": \"name\",\n    \"value\": \"柴胡桂枝汤\",\n    \"text_value\": \"柴胡桂枝汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"桂枝（去皮）1两半，黄芩1两半，人参1两半，甘草1两（炙），半夏2合半（洗），芍药1两半，大枣6枚（擘），生姜1两半（切），柴胡4两。\",\n    \"text_value\": \"柴胡桂枝汤方柴胡（半两） 桂枝（半两） 甘草（一两炙） 黄芩（半两） 人参（半两） 半夏（二合半） 白芍（半两） 生姜（一两半） 大枣（六枚擘）上九味。\",\n    \"components\": [\n      {\n        \"text_name\": \"柴胡\",\n        \"text_count\": \"半两\"\n      },\n      {\n        \"text_name\": \"桂枝\",\n        \"text_count\": \"半两\"\n      },\n      {\n        \"text_name\": \"甘草\",\n        \"text_count\": \"一两炙\"\n      },\n      {\n        \"text_name\": \"黄芩\",\n        \"text_count\": \"半两\"\n      },\n      {\n        \"text_name\": \"人参\",\n        \"text_count\": \"半两\"\n      },\n      {\n        \"text_name\": \"半夏\",\n        \"text_count\": \"二合半\"\n      },\n      {\n        \"text_name\": \"白芍\",\n        \"text_count\": \"半两\"\n      },\n      {\n        \"text_name\": \"生姜\",\n        \"text_count\": \"一两半\"\n      },\n      {\n        \"text_name\": \"大枣\",\n        \"text_count\": \"六枚擘\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"外感风寒，发热自汗，微恶寒，或寒热往来，鼻鸣干呕，头痛项强，胸胁痛满，脉弦或浮大。现用于感冒、癫痫、流行性出血热等。\",\n    \"text_value\": \"外解表邪。内除支结。\"\n  }\n]"