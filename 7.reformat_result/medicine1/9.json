"```json\n[\n  {\n    \"key\": \"name\",\n    \"value\": \"桂枝去芍药加附子汤\",\n    \"text_value\": \"桂枝去芍药汤主之。……方中加附子汤主之。\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"桂枝9克(去皮) 甘草6克(炙) 大枣12枚(擘) 生姜9克(切) 附子5克(炮)\",\n    \"text_value\": \"白术（四两） 甘草（二两） 附子（三枚，炮去皮，破） 生姜（三两，切） 大枣（十二枚，擘）……法当加桂四两。\",\n    \"components\": [\n      {\n        \"text_name\": \"桂\",\n        \"text_count\": \"四两\"\n      },\n      {\n        \"text_name\": \"甘草\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"大枣\",\n        \"text_count\": \"十二枚\"\n      },\n      {\n        \"text_name\": \"生姜\",\n        \"text_count\": \"三两\"\n      },\n      {\n        \"text_name\": \"附子\",\n        \"text_count\": \"三枚\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"解肌祛风，温补阳气而生津液。用于太阳病，误用下法后，脉促胸满，微恶寒者。\",\n    \"text_value\": \"太阳病，下之后，脉促胸满者，中虚而表邪仍在。……微恶寒，则阳亦虚矣，故加附子。\"\n  }\n]\n```"