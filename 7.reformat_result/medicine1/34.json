"[\n  {\n    \"key\": \"name\",\n    \"value\": \"射干麻黄汤\",\n    \"text_value\": \"射干麻黄汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"射干9g，麻黄9g，生姜9g，细辛3g，紫菀6g，款冬花6g，大枣3枚，半夏9g，五味子3g。\",\n    \"text_value\": \"射干十三枚（一法三两）、麻黄四两、生姜四两、细辛三两、五味子半斤、半夏大者（洗）八枚（一法半升）、紫菀三两、款冬花三两、大枣七枚\",\n    \"components\": [\n      {\n        \"text_name\": \"射干\",\n        \"text_count\": \"十三枚（一法三两）\"\n      },\n      {\n        \"text_name\": \"麻黄\",\n        \"text_count\": \"四两\"\n      },\n      {\n        \"text_name\": \"生姜\",\n        \"text_count\": \"四两\"\n      },\n      {\n        \"text_name\": \"细辛\",\n        \"text_count\": \"三两\"\n      },\n      {\n        \"text_name\": \"五味子\",\n        \"text_count\": \"半斤\"\n      },\n      {\n        \"text_name\": \"半夏\",\n        \"text_count\": \"八枚（一法半升）\"\n      },\n      {\n        \"text_name\": \"紫菀\",\n        \"text_count\": \"三两\"\n      },\n      {\n        \"text_name\": \"款冬花\",\n        \"text_count\": \"三两\"\n      },\n      {\n        \"text_name\": \"大枣\",\n        \"text_count\": \"七枚\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"咳而上气，喉中有水鸡声音。\",\n    \"text_value\": \"咳而上气，喉中水鸡声，射干麻黄汤主之。\"\n  }\n]"