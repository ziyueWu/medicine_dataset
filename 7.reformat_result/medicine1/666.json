"[\n  {\n    \"key\": \"name\",\n    \"value\": \"枳实消痞丸\",\n    \"text_value\": \"枳实消痞丸\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"干姜3g  炙甘草  麦芽曲  白茯苓 白术各6g  半夏曲 人参各9g 枳实15g  厚朴12g  黄连6g\",\n    \"text_value\": \"枳实消痞丸枳实（麸炒） 黄连（姜汁炒）五钱 浓朴（姜炒）四钱 半夏曲 麦芽（炒） 人参 白术（土炒）甘草（炙） 茯苓三钱 干姜二钱蒸饼糊丸。\",\n    \"components\": [\n      {\n        \"text_name\": \"枳实（麸炒）\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"黄连（姜汁炒）\",\n        \"text_count\": \"五钱\"\n      },\n      {\n        \"text_name\": \"浓朴（姜炒）\",\n        \"text_count\": \"四钱\"\n      },\n      {\n        \"text_name\": \"半夏曲\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"麦芽（炒）\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"人参\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"白术（土炒）\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"甘草（炙）\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"茯苓\",\n        \"text_count\": \"三钱\"\n      },\n      {\n        \"text_name\": \"干姜\",\n        \"text_count\": \"二钱\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"脾虚气滞，寒热互结证。心下痞满，不欲饮食，倦怠乏力，大便失调。\",\n    \"text_value\": \"脾虚气滞，寒热互结证；见心下痞满，不欲饮食，倦怠乏力，大便失调。\"\n  }\n]"