"[\n  {\n    \"key\": \"name\",\n    \"value\": \"固经丸\",\n    \"text_value\": \"固经丸\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"黄柏（盐炒）300g 黄芩（酒炒）200g 椿皮（炒）150g 香附（醋制）150g 白芍（炒）300g 龟甲（制）400g\",\n    \"text_value\": \"龟板（炙）四两，黄柏（酒炒）、芍药（酒炒）各二两，樗皮（炒）、香附（童便浸炒），各两半，黄芩（酒炒）二两\",\n    \"components\": [\n      {\n        \"text_name\": \"龟板（炙）\",\n        \"text_count\": \"四两\"\n      },\n      {\n        \"text_name\": \"黄柏（酒炒）\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"芍药（酒炒）\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"樗皮（炒）\",\n        \"text_count\": \"两半\"\n      },\n      {\n        \"text_name\": \"香附（童便浸炒）\",\n        \"text_count\": \"两半\"\n      },\n      {\n        \"text_name\": \"黄芩（酒炒）\",\n        \"text_count\": \"二两\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"用于阴虚血热，月经先期，经血量多、色紫黑，赤白带下。 【用途用量】 口服，一次6g，一日2次。 【储藏】 密闭，防潮。\",\n    \"text_value\": \"治经多不止，色紫黑者，属热。阴虚不能制胞络之火，故经多。漏下崩中，色黑殷。\"\n  }\n]"