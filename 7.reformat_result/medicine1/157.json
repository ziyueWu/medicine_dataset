"[\n  {\n    \"key\": \"name\",\n    \"value\": \"猪肤汤\",\n    \"text_value\": \"猪肤汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"猪皮一斤 白粉（米粉）5合 白蜜1升\",\n    \"text_value\": \"猪肤（一斤）…加白蜜一升。白粉五合。\",\n    \"components\": [\n      {\n        \"text_name\": \"猪肤\",\n        \"text_count\": \"一斤\"\n      },\n      {\n        \"text_name\": \"白蜜\",\n        \"text_count\": \"一升\"\n      },\n      {\n        \"text_name\": \"白粉\",\n        \"text_count\": \"五合\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"清热除烦，益津止痛，兼养胃气。用于咽部红肿不甚，疼痛较轻，伴见咽干咽痒，甚或呛咳少痰，或见下利胸满心烦。\",\n    \"text_value\": \"温分六服。\"\n  }\n]"