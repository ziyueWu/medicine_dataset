"[\n  {\n    \"key\": \"name\",\n    \"value\": \"金锁固精丸\",\n    \"text_value\": \"金锁固精\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"沙苑蒺藜、芡实、莲须各60克、龙骨、牡蛎各30克。\",\n    \"text_value\": \"芡实、莲蕊须、沙苑蒺藜炒各二两；龙骨酥炙；牡蛎盐水煮一日夜；粉各三两。\",\n    \"components\": [\n      {\n        \"text_name\": \"芡实\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"莲蕊须\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"沙苑蒺藜\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"龙骨\",\n        \"text_count\": \"三两\"\n      },\n      {\n        \"text_name\": \"牡蛎\",\n        \"text_count\": \"三两\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"肾关不固、遗精滑泄、腰酸耳鸣、四肢无力、脉细弱。\",\n    \"text_value\": \"梦泄多遗，久服蠲。\"\n  }\n]"