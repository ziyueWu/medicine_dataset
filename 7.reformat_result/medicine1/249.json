"```json\n[\n  {\n    \"key\": \"name\",\n    \"value\": \"四君子汤\",\n    \"text_value\": \"四君子汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"人参（去芦）、甘草（炙）、茯苓（去皮）、白术，各等分。\",\n    \"text_value\": \"人参、白术、茯苓各二钱，甘草一钱。\",\n    \"components\": [\n      {\n        \"text_name\": \"人参\",\n        \"text_count\": \"二钱\"\n      },\n      {\n        \"text_name\": \"白术\",\n        \"text_count\": \"二钱\"\n      },\n      {\n        \"text_name\": \"茯苓\",\n        \"text_count\": \"二钱\"\n      },\n      {\n        \"text_name\": \"甘草\",\n        \"text_count\": \"一钱\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"治荣卫气虚，脏腑怯弱，心腹胀满，全不思食，肠鸣泄泻，呕哕吐逆，大宜服之。常服温和脾胃，进益饮食，辟寒邪瘴雾气。\",\n    \"text_value\": \"气味中和，故名君子。四君补气，脾弱阳虚宜之。\"\n  }\n]\n```"