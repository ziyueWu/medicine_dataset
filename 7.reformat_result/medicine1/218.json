"[\n  {\n    \"key\": \"name\",\n    \"value\": \"黄芪建中汤\",\n    \"text_value\": \"黄芪建中汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"黄耆4.5克 桂枝9克（去皮） 甘草6克（炙） 大枣12枚 芍药18克 生姜9克 胶饴30克\",\n    \"text_value\": \"黄芪一两半(4．5克)  桂枝三两(去皮)(9克)  甘草三两(炙)(9克) 大枣十二枚  芍药六两(18克) 生姜二两(6克) 胶饴一升(30克)\",\n    \"components\": [\n      {\n        \"text_name\": \"黄芪\",\n        \"text_count\": \"一两半(4．5克)\"\n      },\n      {\n        \"text_name\": \"桂枝\",\n        \"text_count\": \"三两(9克)\"\n      },\n      {\n        \"text_name\": \"甘草\",\n        \"text_count\": \"三两(9克)\"\n      },\n      {\n        \"text_name\": \"大枣\",\n        \"text_count\": \"十二枚\"\n      },\n      {\n        \"text_name\": \"芍药\",\n        \"text_count\": \"六两(18克)\"\n      },\n      {\n        \"text_name\": \"生姜\",\n        \"text_count\": \"二两(6克)\"\n      },\n      {\n        \"text_name\": \"胶饴\",\n        \"text_count\": \"一升(30克)\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"治虚劳里急，诸不足，小腹急痛，脐下虚满，面色萎黄，唇口干燥，胸中烦悸，少力身重，骨肉酸痛，行动喘乏，食欲不振，病后虚弱，自汗盗汗。\",\n    \"text_value\": \"虚劳里急，诸不足，黄芪建中汤主之。\"\n  }\n]"