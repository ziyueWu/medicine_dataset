"[\n  {\n    \"key\": \"name\",\n    \"value\": \"通脉四逆汤\",\n    \"text_value\": \"通脉四逆\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"炙甘草6g，附子20g，干姜12g。\",\n    \"text_value\": \"甘草（二两炙） 干姜（三两强人四两） 附子（大者一枚生用去皮破八片）上三味\",\n    \"components\": [\n      {\n        \"text_name\": \"甘草（炙）\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"干姜\",\n        \"text_count\": \"三两（强人四两）\"\n      },\n      {\n        \"text_name\": \"附子\",\n        \"text_count\": \"大者一枚（生用去皮破八片）\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"少阴病。下利清谷，里寒外热，手足厥逆，脉微欲绝，身反不恶寒，其人面色赤，或利止。脉不出等。\",\n    \"text_value\": \"其脉即出者愈\"\n  }\n]"