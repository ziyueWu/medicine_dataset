"[\n  {\n    \"key\": \"name\",\n    \"value\": \"碧玉散\",\n    \"text_value\": \"碧玉散\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"软滑石、甘草、青黛\",\n    \"text_value\": \"（滑石六两，甘草一两，灯心汤下……）前方加辰砂，名益元散……加青黛，名碧玉散\",\n    \"components\": [\n      {\n        \"text_name\": \"滑石\",\n        \"text_count\": \"六两\"\n      },\n      {\n        \"text_name\": \"甘草\",\n        \"text_count\": \"一两\"\n      },\n      {\n        \"text_name\": \"青黛\",\n        \"text_count\": \"\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"用于暑热身倦，口渴泄泻，小便黄少，温毒发斑，血热吐衄，胸痛咳血，口疮，痄腮，喉痹，小儿惊痫。\",\n    \"text_value\": \"统治表里及三焦，热渴暑烦泻痢保。……加青黛，名碧玉散，取其凉肝\"\n  }\n]"