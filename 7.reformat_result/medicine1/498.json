"[\n  {\n    \"key\": \"name\",\n    \"value\": \"胶艾汤\",\n    \"text_value\": \"x大胶艾汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"阿胶（炙）3两，艾叶（熬）3两，芍药3两，干地黄3两，当归2两，干姜2两，芎藭2两，甘草（炙）2两。\",\n    \"text_value\": \"x阿胶 艾叶 甘草 当归 芎 （各一两） 干姜（一两） 干地黄 芍药（各三两）\",\n    \"components\": [\n      {\n        \"text_name\": \"阿胶\",\n        \"text_count\": \"各一两\"\n      },\n      {\n        \"text_name\": \"艾叶\",\n        \"text_count\": \"各一两\"\n      },\n      {\n        \"text_name\": \"甘草\",\n        \"text_count\": \"各一两\"\n      },\n      {\n        \"text_name\": \"当归\",\n        \"text_count\": \"各一两\"\n      },\n      {\n        \"text_name\": \"芎\",\n        \"text_count\": \"各一两\"\n      },\n      {\n        \"text_name\": \"干姜\",\n        \"text_count\": \"一两\"\n      },\n      {\n        \"text_name\": \"干地黄\",\n        \"text_count\": \"各三两\"\n      },\n      {\n        \"text_name\": \"芍药\",\n        \"text_count\": \"各三两\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"男子绝伤，或从高堕下，伤损五脏，微者唾血，甚者吐血及金疮伤经内绝；妇人产后及崩中伤下血多，虚喘欲死，腹痛下血不止。\",\n    \"text_value\": \"治男子伤绝。或从高坠下伤五脏。微者吐唾血。及金疮伤经者。兼治妇人产后崩伤。\"\n  }\n]"