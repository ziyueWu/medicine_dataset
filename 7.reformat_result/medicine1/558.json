"[\n  {\n    \"key\": \"name\",\n    \"value\": \"平胃散\",\n    \"text_value\": \"平胃散\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"苍术9克，厚朴(姜制)6克，陈皮(去白)9克，甘草(炙)3克。\",\n    \"text_value\": \"苍术泔浸二钱。浓朴姜汁炒陈皮甘草炙各一钱。姜枣煎。\",\n    \"components\": [\n      {\n        \"text_name\": \"苍术\",\n        \"text_count\": \"二钱\"\n      },\n      {\n        \"text_name\": \"浓朴\",\n        \"text_count\": \"一钱\"\n      },\n      {\n        \"text_name\": \"陈皮\",\n        \"text_count\": \"一钱\"\n      },\n      {\n        \"text_name\": \"甘草炙\",\n        \"text_count\": \"一钱\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"脾土不运，湿浊困中，胸腹胀满，口淡不渴，不思饮食，或有恶心呕吐，大便溏泻，困倦嗜睡，舌不红，苔厚腻。\",\n    \"text_value\": \"脾胃不能克制有积饮痞隔中满者。治湿淫于内。\"\n  }\n]"