"```json\n[\n  {\n    \"key\": \"name\",\n    \"value\": \"十味温胆汤\",\n    \"text_value\": \"十味温胆汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"半夏（汤洗七次） 枳实（去瓤，切，麸炒） 陈皮（去白）各90克 白茯苓（去皮）45克 酸枣仁（微炒） 远志（去心，甘草水煮，姜汁炒） 北五味子 熟地黄（切，酒炒） 条参各30克 粉草15克\",\n    \"text_value\": \"半夏（汤泡） 枳实（麸炒） 陈皮（去白，各二钱）白茯苓（去皮，一钱半） 酸枣仁（炒） 远志（去心，甘草汁煮） 五味子 熟地黄（酒洗，焙） 人参（去芦。各一钱） 粉草（炙，半钱）\",\n    \"components\": [\n      {\n        \"text_name\": \"半夏\",\n        \"text_count\": \"二钱\"\n      },\n      {\n        \"text_name\": \"枳实\",\n        \"text_count\": \"二钱\"\n      },\n      {\n        \"text_name\": \"陈皮\",\n        \"text_count\": \"二钱\"\n      },\n      {\n        \"text_name\": \"白茯苓\",\n        \"text_count\": \"一钱半\"\n      },\n      {\n        \"text_name\": \"酸枣仁\",\n        \"text_count\": \"一钱\"\n      },\n      {\n        \"text_name\": \"远志\",\n        \"text_count\": \"一钱\"\n      },\n      {\n        \"text_name\": \"五味子\",\n        \"text_count\": \"一钱\"\n      },\n      {\n        \"text_name\": \"熟地黄\",\n        \"text_count\": \"一钱\"\n      },\n      {\n        \"text_name\": \"人参\",\n        \"text_count\": \"一钱\"\n      },\n      {\n        \"text_name\": \"粉草\",\n        \"text_count\": \"半钱\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"治心胆虚怯，触事易惊，或梦寐不祥，遂致心惊胆慑，气郁生涎，变生诸证，或短气悸乏，或复自汗，四肢浮肿，饮食无味，心虚烦闷，坐卧不安。\",\n    \"text_value\": \"治证见前温胆汤下。兼治四肢浮肿，饮食无味，心虚烦闷，坐卧不安。\"\n  }\n]\n```"