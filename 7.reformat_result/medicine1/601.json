"[\n  {\n    \"key\": \"name\",\n    \"value\": \"甘草干姜茯苓白术汤\",\n    \"text_value\": \"金匮甘草干姜茯苓白术汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"甘草6g  白术6g  干姜12g  茯苓12g\",\n    \"text_value\": \"甘草二钱。白术干姜茯苓各四钱。\",\n    \"components\": [\n      {\n        \"text_name\": \"甘草\",\n        \"text_count\": \"二钱\"\n      },\n      {\n        \"text_name\": \"白术\",\n        \"text_count\": \"四钱\"\n      },\n      {\n        \"text_name\": \"干姜\",\n        \"text_count\": \"四钱\"\n      },\n      {\n        \"text_name\": \"茯苓\",\n        \"text_count\": \"四钱\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"肾著病。身重腰下冷痛，腰重如带五千钱，如坐冷水中，饮食如故，口不渴，小便自利，舌淡苔白，脉沉迟或沉缓。\",\n    \"text_value\": \"带脉为病。腰溶溶如坐水中。此寒湿之邪。\"\n  }\n]"