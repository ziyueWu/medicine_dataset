"[\n  {\n    \"key\": \"name\",\n    \"value\": \"当归四逆汤\",\n    \"text_value\": \"当归四逆汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"当归9克 桂枝9克（去皮）  芍药9克  细辛3克 甘草6克（炙）  通草6克  大枣5枚\",\n    \"text_value\": \"当归12g 桂枝9g 生白芍9g 细辛3g 炙甘草6g 通草6g 红枣4枚\",\n    \"components\": [\n      {\n        \"text_name\": \"当归\",\n        \"text_count\": \"12g\"\n      },\n      {\n        \"text_name\": \"桂枝\",\n        \"text_count\": \"9g\"\n      },\n      {\n        \"text_name\": \"生白芍\",\n        \"text_count\": \"9g\"\n      },\n      {\n        \"text_name\": \"细辛\",\n        \"text_count\": \"3g\"\n      },\n      {\n        \"text_name\": \"炙甘草\",\n        \"text_count\": \"6g\"\n      },\n      {\n        \"text_name\": \"通草\",\n        \"text_count\": \"6g\"\n      },\n      {\n        \"text_name\": \"红枣\",\n        \"text_count\": \"4枚\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"养血散寒，温经通脉。主厥阴伤寒，血脉凝涩，手足厥寒，脉细欲绝；或肠鸣腹痛，下利不止；或阴颓疝气，睾丸掣痛，牵引少腹。现用于雷诺氏病、血栓闭塞性脉管炎、坐骨神经痛、风湿性关节炎、腰腿足踝酸痛、胃十二指肠溃疡、慢性荨麻疹、精索静脉曲张、女子闭经、痛经、月经不调、冻疮、皲裂等属血虚寒凝经脉者。\",\n    \"text_value\": \"血虚受寒，症见手足厥冷，舌淡苔白、脉沉细或脉细欲绝者。\"\n  }\n]"