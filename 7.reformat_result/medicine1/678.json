"[\n  {\n    \"key\": \"name\",\n    \"value\": \"瓜蒂散\",\n    \"text_value\": \"瓜蒂散\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"瓜蒂一份（熬黄） 赤小豆一份\",\n    \"text_value\": \"瓜蒂（一分熬黄） 赤小豆（三分煮）上二味\",\n    \"components\": [\n      {\n        \"text_name\": \"瓜蒂\",\n        \"text_count\": \"一分\"\n      },\n      {\n        \"text_name\": \"赤小豆\",\n        \"text_count\": \"三分\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"涌吐痰食。治痰涎宿食填塞上脘，胸中痞硬，烦懊不安，气上冲咽喉不得息，舌苔厚腻，寸脉微浮者。\",\n    \"text_value\": \"食在上脘者。则不当下而当吐。经云。其高者因而越之也。\"\n  }\n]"