"[\n  {\n    \"key\": \"name\",\n    \"value\": \"泰山磐石散\",\n    \"text_value\": \"泰山磐石散\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"人参3克，黄芪6克，白术6克，炙甘草2克，当归3克，川芎2克，白芍药3克，熟地黄3克，川续断3克，糯米6克，黄芩3克，砂仁1.5克。\",\n    \"text_value\": \"台党、炙 、川芎、黄芩、川续断各一钱，白芍（酒炒）、熟地各八分，白术二钱土炒，炙草、砂仁各五分，糯米（三钱），用泉水煎服。\",\n    \"components\": [\n      {\n        \"text_name\": \"台党\",\n        \"text_count\": \"一钱\"\n      },\n      {\n        \"text_name\": \"炙\",\n        \"text_count\": \"一钱\"\n      },\n      {\n        \"text_name\": \"川芎\",\n        \"text_count\": \"一钱\"\n      },\n      {\n        \"text_name\": \"黄芩\",\n        \"text_count\": \"一钱\"\n      },\n      {\n        \"text_name\": \"川续断\",\n        \"text_count\": \"一钱\"\n      },\n      {\n        \"text_name\": \"白芍（酒炒）\",\n        \"text_count\": \"八分\"\n      },\n      {\n        \"text_name\": \"熟地\",\n        \"text_count\": \"八分\"\n      },\n      {\n        \"text_name\": \"白术（土炒）\",\n        \"text_count\": \"二钱\"\n      },\n      {\n        \"text_name\": \"炙草\",\n        \"text_count\": \"五分\"\n      },\n      {\n        \"text_name\": \"砂仁\",\n        \"text_count\": \"五分\"\n      },\n      {\n        \"text_name\": \"糯米\",\n        \"text_count\": \"三钱\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"气血虚弱所致的堕胎、滑胎。胎动不安，或屡有堕胎宿疾，面色淡白，倦怠乏力，不思饮食，舌淡苔薄白，脉滑无力。\",\n    \"text_value\": \"治妇人血气两虚。或肥而不实，或瘦而血热，或肝脾素亏，倦怠少食，屡有堕胎之患。\"\n  }\n]"