"[\n  {\n    \"key\": \"name\",\n    \"value\": \"桂枝附子汤\",\n    \"text_value\": \"桂枝附子汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"桂枝4两（去皮)，附子3枚（炮，去皮)，生姜3两（切)，大枣12枚（擘)，甘草2两（炙)。\",\n    \"text_value\": \"桂枝（四两去皮） 附子（三枚炮去皮破八片） 生姜（三两切） 甘草（二两炙） 大枣（十二枚擘）\",\n    \"components\": [\n      {\n        \"text_name\": \"桂枝\",\n        \"text_count\": \"四两\"\n      },\n      {\n        \"text_name\": \"附子\",\n        \"text_count\": \"三枚\"\n      },\n      {\n        \"text_name\": \"生姜\",\n        \"text_count\": \"三两\"\n      },\n      {\n        \"text_name\": \"大枣\",\n        \"text_count\": \"十二枚\"\n      },\n      {\n        \"text_name\": \"甘草\",\n        \"text_count\": \"二两\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"伤寒8-9日，风湿相搏，身体疼烦，不能自转侧，不呕不渴，脉浮虚而涩者。恶寒发热，四肢掣痛，难以屈伸，或心下悸，或脐下悸。\",\n    \"text_value\": \"风在表者。散以桂枝甘草之辛甘。\"\n  }\n]"