"[\n  {\n    \"key\": \"name\",\n    \"value\": \"香砂六君子汤\",\n    \"text_value\": \"香砂六君子汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"人参1钱，白术1钱，茯苓1钱，半夏1钱，陈皮1钱，藿香8分，甘草（炒）6分，宿砂仁（炒）8分。\",\n    \"text_value\": \"人参（一钱） 白术（二钱） 茯苓（二钱） 甘草（七分） 陈皮（八分） 半夏（一钱） 砂仁（八分） 木香（七分）上生姜二钱\",\n    \"components\": [\n      {\n        \"text_name\": \"人参\",\n        \"text_count\": \"一钱\"\n      },\n      {\n        \"text_name\": \"白术\",\n        \"text_count\": \"二钱\"\n      },\n      {\n        \"text_name\": \"茯苓\",\n        \"text_count\": \"二钱\"\n      },\n      {\n        \"text_name\": \"甘草\",\n        \"text_count\": \"七分\"\n      },\n      {\n        \"text_name\": \"陈皮\",\n        \"text_count\": \"八分\"\n      },\n      {\n        \"text_name\": \"半夏\",\n        \"text_count\": \"一钱\"\n      },\n      {\n        \"text_name\": \"砂仁\",\n        \"text_count\": \"八分\"\n      },\n      {\n        \"text_name\": \"木香\",\n        \"text_count\": \"七分\"\n      },\n      {\n        \"text_name\": \"生姜\",\n        \"text_count\": \"二钱\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"脾胃虚寒，恶心呕吐，食欲不振，或口舌生疮。\",\n    \"text_value\": \"香砂六君子汤治气虚痰饮，呕吐痞闷，脾胃不和，变生诸证者。\"\n  }\n]"