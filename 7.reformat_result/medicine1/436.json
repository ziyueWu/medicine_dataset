"[\n  {\n    \"key\": \"name\",\n    \"value\": \"干姜人参半夏丸\",\n    \"text_value\": \"干姜人参半夏丸\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"干姜 人参各14克 半夏28克\",\n    \"text_value\": \"干姜4．5克，党参9克，半夏4．5克。\",\n    \"components\": [\n      {\n        \"text_name\": \"干姜\",\n        \"text_count\": \"4．5克\"\n      },\n      {\n        \"text_name\": \"党参\",\n        \"text_count\": \"9克\"\n      },\n      {\n        \"text_name\": \"半夏\",\n        \"text_count\": \"4．5克\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"妇人妊娠呕吐不止。 【注】 本方改为汤剂，名“干姜人参半夏汤”（见《产科发蒙》）。\",\n    \"text_value\": \"适时将近1个月，渐至水饮不入，食入则吐，所吐皆痰涎清水……时时呕吐增剧。\"\n  }\n]"