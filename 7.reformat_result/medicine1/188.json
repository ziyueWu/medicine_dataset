"[\n  {\n    \"key\": \"name\",\n    \"value\": \"泻黄散\",\n    \"text_value\": \"泻黄散\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"藿香叶（21克） 山桅仁（3克） 石膏（15克） 甘草（90克） 防风（120克）\",\n    \"text_value\": \"藿香叶（去土，七钱） 石膏（ ） 缩砂（去壳） 山栀子（去壳） 甘草（炙。各半两） 防风（上锉碎，同蜜、酒炒香，焙，为细末。\",\n    \"components\": [\n      {\n        \"text_name\": \"藿香叶\",\n        \"text_count\": \"七钱\"\n      },\n      {\n        \"text_name\": \"山桅仁\",\n        \"text_count\": \"各半两\"\n      },\n      {\n        \"text_name\": \"石膏\",\n        \"text_count\": \"各半两\"\n      },\n      {\n        \"text_name\": \"甘草\",\n        \"text_count\": \"各半两\"\n      },\n      {\n        \"text_name\": \"防风\",\n        \"text_count\": \"各半两\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"脾胃伏火证。目疮口臭，烦渴易饥，口燥唇干，舌红脉数，以及脾热弄舌等。\",\n    \"text_value\": \"治脾胃壅实，口内生疮，烦闷多渴，颊痛心烦，唇口干燥，壅滞不食。\"\n  }\n]"