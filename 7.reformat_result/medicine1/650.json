"[\n  {\n    \"key\": \"name\",\n    \"value\": \"半夏白术天麻汤\",\n    \"text_value\": \"半夏白术天麻汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"半夏9g  天麻 茯苓 橘红各6g  白术15g 甘草3g\",\n    \"text_value\": \"天麻（半钱） 半夏（一钱半） 黄 （半钱） 人参（半钱） 白术（一钱） 苍术 橘 皮泽 泻\",\n    \"components\": [\n      {\n        \"text_name\": \"天麻\",\n        \"text_count\": \"半钱\"\n      },\n      {\n        \"text_name\": \"半夏\",\n        \"text_count\": \"一钱半\"\n      },\n      {\n        \"text_name\": \"黄\",\n        \"text_count\": \"半钱\"\n      },\n      {\n        \"text_name\": \"人参\",\n        \"text_count\": \"半钱\"\n      },\n      {\n        \"text_name\": \"白术\",\n        \"text_count\": \"一钱\"\n      },\n      {\n        \"text_name\": \"苍术\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"橘\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"皮\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"泽\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"泻\",\n        \"text_count\": \"\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"风痰上扰证。眩晕头痛，胸闷呕恶，舌苔白腻，脉弦滑等。\",\n    \"text_value\": \"病名曰痰厥头痛。与半夏白术天麻汤治之。此头痛苦甚。为足太阴痰厥头痛。眼黑头旋。\"\n  }\n]"