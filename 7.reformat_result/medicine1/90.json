"[\n  {\n    \"key\": \"name\",\n    \"value\": \"一物瓜蒂汤\",\n    \"text_value\": \"一名一物瓜蒂汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"瓜蒂2-7个\",\n    \"text_value\": \"捣碎。以水一中盏。煎至五分。去滓温服。一名一物瓜蒂汤。\",\n    \"components\": [\n      {\n        \"text_name\": \"瓜蒂\",\n        \"text_count\": \"2-7个\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"泻水湿停饮。太阳中暍，身热疼重，而脉微弱，此以夏月伤冷水，水行皮中所致，身面四肢浮肿。\",\n    \"text_value\": \"太阳中。身热疼重。而脉微弱。此以夏月伤冷水。水行皮中所致也。\"\n  }\n]"