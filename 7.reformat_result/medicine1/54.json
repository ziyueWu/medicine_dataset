"[\n  {\n    \"key\": \"name\",\n    \"value\": \"千金葳蕤汤\",\n    \"text_value\": \"葳蕤汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"玉竹、白薇、独活、杏仁、麻黄、川芎、甘草、青木香、石膏各6克(如无木香，可用麝香0.3克代之)\",\n    \"text_value\": \"葳蕤 白薇 麻黄 独活 杏仁 芎 甘草 青木香（各二两）石膏（三两）上九味\",\n    \"components\": [\n      {\n        \"text_name\": \"葳蕤\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"白薇\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"麻黄\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"独活\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"杏仁\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"芎\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"甘草\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"青木香\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"石膏\",\n        \"text_count\": \"三两\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"阴虚外感风热，发热头痛，咽干舌燥，气喘有汗，胸脘痞闷，体重嗜睡，苔白，脉浮者。\",\n    \"text_value\": \"但吐下之。则遗失便利如此疾者。宜服之方。\"\n  }\n]"