"[\n  {\n    \"key\": \"name\",\n    \"value\": \"调胃承气汤\",\n    \"text_value\": \"调胃承气汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"大黄12克（去皮，清酒洗） 甘草6克（炙） 芒硝15克\",\n    \"text_value\": \"纳芒硝。调胃承气汤。以甘草缓硝黄下行之性。\",\n    \"components\": [\n      {\n        \"text_name\": \"芒硝\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"甘草\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"大黄\",\n        \"text_count\": \"\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"缓下热结。主阳明病胃肠燥热。蒸蒸发热，口渴便秘，腹满拒按，舌苔正黄，脉滑数；亦用于肠胃热盛而见发斑吐衄，口齿咽喉肿痛，中消，疮疡等。\",\n    \"text_value\": \"以清热而导滞。盖热邪聚胃。以甘草缓硝黄下行之性。\"\n  }\n]"