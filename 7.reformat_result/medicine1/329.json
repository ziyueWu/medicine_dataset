"[\n  {\n    \"key\": \"name\",\n    \"value\": \"虎潜丸\",\n    \"text_value\": \"加味虎潜丸\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"黄柏（酒炒，240克） 龟板（酒炙，120克） 知母（酒炒，60克） 生地黄（60克） 陈皮（60克） 白芍（60克） 锁阳（45克） 虎骨（用狗骨代，炙，30克） 干姜（15克）\",\n    \"text_value\": \"黄柏知母熟地各三两。龟板四两。白芍当归牛膝各二两。虎胫骨琐阳陈皮各一两五钱。干姜五钱。酒煮羯羊肉为丸。\",\n    \"components\": [\n      {\n        \"text_name\": \"黄柏\",\n        \"text_count\": \"三两\"\n      },\n      {\n        \"text_name\": \"知母\",\n        \"text_count\": \"三两\"\n      },\n      {\n        \"text_name\": \"熟地\",\n        \"text_count\": \"三两\"\n      },\n      {\n        \"text_name\": \"龟板\",\n        \"text_count\": \"四两\"\n      },\n      {\n        \"text_name\": \"白芍\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"当归\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"牛膝\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"虎胫骨\",\n        \"text_count\": \"一两五钱\"\n      },\n      {\n        \"text_name\": \"琐阳\",\n        \"text_count\": \"一两五钱\"\n      },\n      {\n        \"text_name\": \"陈皮\",\n        \"text_count\": \"一两五钱\"\n      },\n      {\n        \"text_name\": \"干姜\",\n        \"text_count\": \"五钱\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"肝肾不足，阴虚内热之痿证。腰膝酸软，筋骨痿弱，腿足消瘦，步履乏力，或眩晕，耳鸣，遗精，遗尿，舌红少苔，脉细弱。\",\n    \"text_value\": \"治诸虚不足。\"\n  }\n]"