"[\n  {\n    \"key\": \"name\",\n    \"value\": \"清骨散\",\n    \"text_value\": \"清骨散\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"银柴胡5克,胡黄连、秦艽、鳖甲、地骨皮、青蒿、知母各3克,甘草2克。\",\n    \"text_value\": \"清骨散银柴胡一钱五分 胡黄连 秦艽 鳖甲（童便炙） 地骨皮 青蒿 知母二钱 甘草（炙）五分\",\n    \"components\": [\n      {\n        \"text_name\": \"银柴胡\",\n        \"text_count\": \"一钱五分\"\n      },\n      {\n        \"text_name\": \"胡黄连\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"秦艽\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"鳖甲（童便炙）\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"地骨皮\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"青蒿\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"知母\",\n        \"text_count\": \"二钱\"\n      },\n      {\n        \"text_name\": \"甘草（炙）\",\n        \"text_count\": \"五分\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"骨蒸潮热证,表现为午後或夜间潮热,骨蒸心烦,形瘦盗汗,两颊潮红,手足心热,舌红少苔,脉细数。肺结核、其他慢性消耗性疾病等证属阴虚内热、虚劳骨蒸者,可用本方加减治疗。\",\n    \"text_value\": \"病至骨蒸劳热，全是有阳无阴矣。\"\n  }\n]"