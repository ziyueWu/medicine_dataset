"[\n  {\n    \"key\": \"name\",\n    \"value\": \"八珍汤\",\n    \"text_value\": \"八珍汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"人参30克，白术30克，白茯苓30克，当归30克，川芎30克，白芍药30克，熟地黄30克，炙甘草30克。\",\n    \"text_value\": \"人参、茯苓、川芎、当归、炒白芍、地黄各一钱，白术一钱五分，炙甘草五分\",\n    \"components\": [\n      {\n        \"text_name\": \"人参\",\n        \"text_count\": \"一钱\"\n      },\n      {\n        \"text_name\": \"茯苓\",\n        \"text_count\": \"一钱\"\n      },\n      {\n        \"text_name\": \"川芎\",\n        \"text_count\": \"一钱\"\n      },\n      {\n        \"text_name\": \"当归\",\n        \"text_count\": \"一钱\"\n      },\n      {\n        \"text_name\": \"炒白芍\",\n        \"text_count\": \"一钱\"\n      },\n      {\n        \"text_name\": \"地黄\",\n        \"text_count\": \"一钱\"\n      },\n      {\n        \"text_name\": \"白术\",\n        \"text_count\": \"一钱五分\"\n      },\n      {\n        \"text_name\": \"炙甘草\",\n        \"text_count\": \"五分\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"气血两虚证。面色苍白或萎黄，头晕耳眩，四肢倦怠，气短懒言，心悸怔忡，饮食减少，舌淡苔薄白，脉细弱或虚大无力。 本方常用于病后虚弱、各种慢性病，以及妇女月经不调等属气血两虚者。\",\n    \"text_value\": \"原文未载（仅载“水煎服”）\"\n  }\n]"