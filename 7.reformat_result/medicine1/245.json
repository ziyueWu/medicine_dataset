"[\n  {\n    \"key\": \"name\",\n    \"value\": \"附子粳米汤\",\n    \"text_value\": \"附子粳米汤方\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"附子1枚（炮），半夏半升，甘草1两，大枣10枚，粳米半升。\",\n    \"text_value\": \"附子（一枚炮） 半夏 粳米（各半升） 甘草（一两） 大枣（十枚）上五味。\",\n    \"components\": [\n      {\n        \"text_name\": \"附子\",\n        \"text_count\": \"一枚（炮）\"\n      },\n      {\n        \"text_name\": \"半夏\",\n        \"text_count\": \"半升\"\n      },\n      {\n        \"text_name\": \"粳米\",\n        \"text_count\": \"半升\"\n      },\n      {\n        \"text_name\": \"甘草\",\n        \"text_count\": \"一两\"\n      },\n      {\n        \"text_name\": \"大枣\",\n        \"text_count\": \"十枚\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"温阳化饮，和中缓急。主腹中寒气，雷鸣切痛，胸胁逆满呕吐。\",\n    \"text_value\": \"半夏降逆止呕。而尤赖粳米、甘、枣。培令土浓。而使敛阴气也。\"\n  }\n]"