"[\n  {\n    \"key\": \"name\",\n    \"value\": \"瓜蒌薤白半夏汤\",\n    \"text_value\": \"栝蒌薤白半夏汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"瓜蒌实12克，薤白、半夏各9克，白酒70毫升（非现代之白酒，实为黄酒，或用醪糟代之亦可。)\",\n    \"text_value\": \"栝蒌实（一枚捣） 薤白（三两） 半夏（半升） 白酒（一斗）上四味\",\n    \"components\": [\n      {\n        \"text_name\": \"栝蒌实\",\n        \"text_count\": \"一枚\"\n      },\n      {\n        \"text_name\": \"薤白\",\n        \"text_count\": \"三两\"\n      },\n      {\n        \"text_name\": \"半夏\",\n        \"text_count\": \"半升\"\n      },\n      {\n        \"text_name\": \"白酒\",\n        \"text_count\": \"一斗\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"痰盛瘀阻胸痹证。症见胸中满痛彻背，背痛彻胸，不能安卧者，短气，或痰多粘而白，舌质紫暗或有暗点，苔白或腻，脉迟。\",\n    \"text_value\": \"胸痹\"\n  }\n]"