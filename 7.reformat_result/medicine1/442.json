"[\n  {\n    \"key\": \"name\",\n    \"value\": \"枳实薤白桂枝汤\",\n    \"text_value\": \"枳实薤白桂枝汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"枳实12g，厚朴12g，薤白9g，桂枝3g，瓜蒌实 12g。\",\n    \"text_value\": \"枳实四枚(9克)  厚朴四两(12克)  薤白半斤(9克)  桂枝一两(3克)  栝蒌实一枚(捣)(15克)\",\n    \"components\": [\n      {\n        \"text_name\": \"枳实\",\n        \"text_count\": \"四枚(9克)\"\n      },\n      {\n        \"text_name\": \"厚朴\",\n        \"text_count\": \"四两(12克)\"\n      },\n      {\n        \"text_name\": \"薤白\",\n        \"text_count\": \"半斤(9克)\"\n      },\n      {\n        \"text_name\": \"桂枝\",\n        \"text_count\": \"一两(3克)\"\n      },\n      {\n        \"text_name\": \"栝蒌实\",\n        \"text_count\": \"一枚(捣)(15克)\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"通阳散结，下气祛痰。用于胸痹。症见气结在胸，胸满而痛，心中痞气，气从胁下上逆抢心，舌苔白腻，脉沉弦或紧。\",\n    \"text_value\": \"胸痹心中痞，留气结在胸，胸满，胁下逆抢心，枳实薤白桂枝汤主之。\"\n  }\n]"