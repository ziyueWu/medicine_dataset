"```json\n[\n  {\n    \"key\": \"name\",\n    \"value\": \"麻子仁丸\",\n    \"text_value\": \"麻子仁丸\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"火麻仁（麻子仁）500克 芍药250克 枳实250克 大黄500克 厚朴250克 杏仁250克\",\n    \"text_value\": \"麻子仁二升、芍药半斤、枳实半斤（炙）、大黄一斤（去皮）、厚朴一尺（炙，去皮）、杏仁一升（去皮尖，熬，别作脂）\",\n    \"components\": [\n      {\n        \"text_name\": \"麻子仁\",\n        \"text_count\": \"二升\"\n      },\n      {\n        \"text_name\": \"芍药\",\n        \"text_count\": \"半斤\"\n      },\n      {\n        \"text_name\": \"枳实\",\n        \"text_count\": \"半斤\"\n      },\n      {\n        \"text_name\": \"大黄\",\n        \"text_count\": \"一斤\"\n      },\n      {\n        \"text_name\": \"厚朴\",\n        \"text_count\": \"一尺\"\n      },\n      {\n        \"text_name\": \"杏仁\",\n        \"text_count\": \"一升\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"肠胃燥热，津液不足。大便干结，小便频数。本方常用于虚人及老人肠燥便秘、习惯性便秘、产后便秘、痔疮术后便秘等属胃肠燥热者。\",\n    \"text_value\": \"此治素贯脾约之人，复感外邪，预防燥结之法。方中用麻杏仁以润肠燥，芍药以养阴血，枳实大黄以泄实热，厚朴以破滞气也。\"\n  }\n]\n```"