"[\n  {\n    \"key\": \"name\",\n    \"value\": \"三物备急丸\",\n    \"text_value\": \"姜豆大黄备急丸\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"大黄30克，巴豆(炒研如脂或用霜)30克，干姜30克。\",\n    \"text_value\": \"干姜大黄各二两。巴豆一两。去皮研如脂。和蜜丸如豆大。\",\n    \"components\": [\n      {\n        \"text_name\": \"干姜\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"大黄\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"巴豆\",\n        \"text_count\": \"一两\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"食停肠胃，卒然心腹胀痛，痛如锥刺，四肢厥逆，苔白而润，脉象沉紧或迟者。\",\n    \"text_value\": \"专攻闭痛及停寒。兼疗中恶人昏倒。\"\n  }\n]"