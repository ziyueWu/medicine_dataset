"[\n  {\n    \"key\": \"name\",\n    \"value\": \"白头翁汤\",\n    \"text_value\": \"白头翁汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"白头翁15克  黄柏12克  黄连6克  秦皮12克\",\n    \"text_value\": \"白头翁（二两） 黄连 黄柏 秦皮（各三两）\",\n    \"components\": [\n      {\n        \"text_name\": \"白头翁\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"黄柏\",\n        \"text_count\": \"三两\"\n      },\n      {\n        \"text_name\": \"黄连\",\n        \"text_count\": \"三两\"\n      },\n      {\n        \"text_name\": \"秦皮\",\n        \"text_count\": \"三两\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"热毒痢疾。腹痛，里急后重，肛门灼热，下痢脓血，赤多白少，渴欲饮水，舌红苔黄，脉弦数。本方常用于阿米巴痢疾、细菌性痢疾属热毒偏盛者。\",\n    \"text_value\": \"治痢，口渴下重者如神。热利下重者，白头翁汤主之。下利欲饮水者，以有热故也，白头翁汤主之。\"\n  }\n]"