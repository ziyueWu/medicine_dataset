"[\n  {\n    \"key\": \"name\",\n    \"value\": \"白术附子汤\",\n    \"text_value\": \"白术附子汤方\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"白术6克 附子10克(炮，去皮) 甘草3克(炙) 生姜4.5克(切) 大枣6枚\",\n    \"text_value\": \"白术（一两） 附子（一枚炮去皮） 甘草（二两炙） 生姜（一两半） 大枣（六枚）上五味。\",\n    \"components\": [\n      {\n        \"text_name\": \"白术\",\n        \"text_count\": \"一两\"\n      },\n      {\n        \"text_name\": \"附子\",\n        \"text_count\": \"一枚\"\n      },\n      {\n        \"text_name\": \"甘草\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"生姜\",\n        \"text_count\": \"一两半\"\n      },\n      {\n        \"text_name\": \"大枣\",\n        \"text_count\": \"六枚\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"风湿相搏，身体疼烦，不能自转侧，不呕不渴，脉浮虚而涩，大便坚，小便自利者。\",\n    \"text_value\": \"一服觉身痹。\"\n  }\n]"