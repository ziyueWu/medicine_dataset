"[\n  {\n    \"key\": \"name\",\n    \"value\": \"四逆散\",\n    \"text_value\": \"四逆散\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"甘草（炙）、枳实、（破，水渍，炙干）柴胡、芍药各等分\",\n    \"text_value\": \"方用柴胡、枳实、芍药、甘草。\",\n    \"components\": [\n      {\n        \"text_name\": \"柴胡\",\n        \"text_count\": \"各等分\"\n      },\n      {\n        \"text_name\": \"枳实\",\n        \"text_count\": \"各等分\"\n      },\n      {\n        \"text_name\": \"芍药\",\n        \"text_count\": \"各等分\"\n      },\n      {\n        \"text_name\": \"甘草\",\n        \"text_count\": \"各等分\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"疏肝和脾，解郁透热。治少阴病，阳郁于里，致患热厥；以及肝失条达，气郁致厥，手足厥冷，或咳，或悸，或小便不利，或腹中痛，或泄痢下重，脉弦细。\",\n    \"text_value\": \"或小便不利。或腹中痛。或泄利下重者。四逆散主之。\"\n  }\n]"