"[\n  {\n    \"key\": \"name\",\n    \"value\": \"三拗汤\",\n    \"text_value\": \"三拗汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"麻黄（不去节），杏仁（不去皮尖），甘草（不炙）。各30克。\",\n    \"text_value\": \"麻黄（不去节用） 杏仁（不去皮失） 甘草（不炙）上三味等分， 咀，每服五钱，水二盏，煎至八分，热服，以被盖覆而睡。\",\n    \"components\": [\n      {\n        \"text_name\": \"麻黄\",\n        \"text_count\": \"等分\"\n      },\n      {\n        \"text_name\": \"杏仁\",\n        \"text_count\": \"等分\"\n      },\n      {\n        \"text_name\": \"甘草\",\n        \"text_count\": \"等分\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"感冒风邪，鼻塞声重，语音不出，咳嗽胸闷。\",\n    \"text_value\": \"治冬月感冒寒气，暴嗽痰喘\"\n  }\n]"