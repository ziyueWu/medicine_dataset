"[\n  {\n    \"key\": \"name\",\n    \"value\": \"葛根加半夏汤\",\n    \"text_value\": \"葛根汤原方。桂枝汤原方。加半夏半升。加葛根四两。\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"葛根12克 麻黄9克(去节) 甘草6克(炙) 芍药6克 桂枝6克(去皮) 生姜6克(切) 半夏9克(洗) 大枣12枚(擘)\",\n    \"text_value\": \"葛根汤原方。桂枝汤原方。加半夏半升。加葛根四两。桂枝芍药各减一两。\",\n    \"components\": [\n      {\n        \"text_name\": \"葛根\",\n        \"text_count\": \"四两\"\n      },\n      {\n        \"text_name\": \"麻黄\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"甘草\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"芍药\",\n        \"text_count\": \"各减一两\"\n      },\n      {\n        \"text_name\": \"桂枝\",\n        \"text_count\": \"各减一两\"\n      },\n      {\n        \"text_name\": \"生姜\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"半夏\",\n        \"text_count\": \"半升\"\n      },\n      {\n        \"text_name\": \"大枣\",\n        \"text_count\": \"\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"外感风寒，头痛，项背强直拘急，无汗，口不渴，呕逆，苔白，脉浮者。\",\n    \"text_value\": \"太阳与阳明合病者。必自下利。葛根汤主之。\"\n  }\n]"