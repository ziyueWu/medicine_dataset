"[\n  {\n    \"key\": \"name\",\n    \"value\": \"黄龙汤\",\n    \"text_value\": \"黄龙汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"大黄 芒硝各3克 枳实 厚朴 人参 当归各2.4克 甘草2克\",\n    \"text_value\": \"大黄 芒硝 枳实 浓朴 甘草 人参 当归（年老气血虚者，去芒硝）。水二钟，姜三片，枣子二枚。后再加桔梗。\",\n    \"components\": [\n      {\n        \"text_name\": \"大黄\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"芒硝\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"枳实\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"浓朴\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"甘草\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"人参\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"当归\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"姜\",\n        \"text_count\": \"三片\"\n      },\n      {\n        \"text_name\": \"枣子\",\n        \"text_count\": \"二枚\"\n      },\n      {\n        \"text_name\": \"水\",\n        \"text_count\": \"二钟\"\n      },\n      {\n        \"text_name\": \"桔梗\",\n        \"text_count\": \"\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"肠胃燥热，气血两虚。下利清水，神昏谵语，腹痛拒按，身热而渴，神疲少气，舌苔焦黄或焦黑，脉沉细数者。 【方论】 方中以大承气汤之大黄、芒消、枳实、厚朴荡涤胃肠实热，急下存阴；\\n\\n人参、当归双补气血，扶正以助祛邪；桔梗宣肺而通大肠；\\n\\n生姜、大枣、甘草和胃气而兼调诸药，共奏抉正攻下之功。\",\n    \"text_value\": \"治患心下硬痛，下利纯清水，谵语发渴，身热（结热利证；身有热者宜用此汤）。\"\n  }\n]"