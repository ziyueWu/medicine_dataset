"```json\n[\n  {\n    \"key\": \"name\",\n    \"value\": \"藿香正气散\",\n    \"text_value\": \"藿香正气散（散，《局方》）\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"藿香9克、紫苏6克、白芷6克、大腹皮12克、茯苓12克、白术9克、陈皮6克、厚朴9克、半夏9克、桔梗6克、甘草6克、生姜6克、大枣2枚。\",\n    \"text_value\": \"藿香、大腹皮、紫苏、茯苓、白芷各三两，陈皮、白术（土炒）、浓朴（姜汁炒）、半夏曲、桔梗各二两，甘草一两，每服五钱，加姜、枣煎。\",\n    \"components\": [\n      {\n        \"text_name\": \"藿香\",\n        \"text_count\": \"三两\"\n      },\n      {\n        \"text_name\": \"紫苏\",\n        \"text_count\": \"三两\"\n      },\n      {\n        \"text_name\": \"白芷\",\n        \"text_count\": \"三两\"\n      },\n      {\n        \"text_name\": \"大腹皮\",\n        \"text_count\": \"三两\"\n      },\n      {\n        \"text_name\": \"茯苓\",\n        \"text_count\": \"三两\"\n      },\n      {\n        \"text_name\": \"陈皮\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"白术（土炒）\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"浓朴（姜汁炒）\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"半夏曲\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"桔梗\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"甘草\",\n        \"text_count\": \"一两\"\n      },\n      {\n        \"text_name\": \"生姜\",\n        \"text_count\": \"加姜（未注明量）\"\n      },\n      {\n        \"text_name\": \"大枣\",\n        \"text_count\": \"加枣（未注明量）\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"外感风寒，内伤湿滞所致的恶寒发热，头痛，胸膈满闷，脘腹疼痛，恶心呕吐，肠鸣腹泻、口淡，舌苔白腻等。\",\n    \"text_value\": \"感伤（外感内伤）岚瘴并能驱；藿香理气和中，辟恶止呕；气行血活自经匀（气行则血行，经自调，而痛自止）。\"\n  }\n]\n```"