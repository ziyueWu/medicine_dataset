"[\n  {\n    \"key\": \"name\",\n    \"value\": \"朱砂安神丸\",\n    \"text_value\": \"安神丸\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"朱砂半两  黄连六钱  炙甘草五钱半  生地二钱半  当归二钱半\",\n    \"text_value\": \"归草朱连生地黄。（朱砂另研黄连各半两。生地黄三钱。当归甘草各二钱为末。\",\n    \"components\": [\n      {\n        \"text_name\": \"朱砂\",\n        \"text_count\": \"半两\"\n      },\n      {\n        \"text_name\": \"黄连\",\n        \"text_count\": \"半两\"\n      },\n      {\n        \"text_name\": \"生地黄\",\n        \"text_count\": \"三钱\"\n      },\n      {\n        \"text_name\": \"当归\",\n        \"text_count\": \"二钱\"\n      },\n      {\n        \"text_name\": \"甘草\",\n        \"text_count\": \"二钱\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"心火亢盛，阴血不足证。失眠多梦，惊悸怔忡，心烦神乱，舌红，脉细数。\",\n    \"text_value\": \"安神丸剂亦寻常。……每服三十丸。临卧时津液下。\"\n  }\n]"