"[\n  {\n    \"key\": \"name\",\n    \"value\": \"麻杏甘石汤\",\n    \"text_value\": \"麻杏石甘汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"麻黄6克、杏仁9克、生石膏24克、甘草6克。\",\n    \"text_value\": \"麻杏石甘汤（麻黄6克，杏仁6克，生石膏18克，炙甘草6克）加蝉蜕12克，丹皮9克、白蒺藜12克，白鲜皮12克\",\n    \"components\": [\n      {\n        \"text_name\": \"麻黄\",\n        \"text_count\": \"6克\"\n      },\n      {\n        \"text_name\": \"杏仁\",\n        \"text_count\": \"6克\"\n      },\n      {\n        \"text_name\": \"生石膏\",\n        \"text_count\": \"18克\"\n      },\n      {\n        \"text_name\": \"炙甘草\",\n        \"text_count\": \"6克\"\n      },\n      {\n        \"text_name\": \"蝉蜕\",\n        \"text_count\": \"12克\"\n      },\n      {\n        \"text_name\": \"丹皮\",\n        \"text_count\": \"9克\"\n      },\n      {\n        \"text_name\": \"白蒺藜\",\n        \"text_count\": \"12克\"\n      },\n      {\n        \"text_name\": \"白鲜皮\",\n        \"text_count\": \"12克\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": null,\n    \"text_value\": \"治疗荨麻疹（常年皮肤搔痒，大片红色疹块蔓延周身），三剂而告愈；后嘱每月初服三剂，五年未复发\"\n  }\n]"