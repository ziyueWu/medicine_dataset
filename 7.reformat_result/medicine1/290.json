"[\n  {\n    \"key\": \"name\",\n    \"value\": \"当归补血汤\",\n    \"text_value\": \"古有当归补血汤。\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"黄芪30克，当归6克。\",\n    \"text_value\": \"五倍黄 归一分。黄 一两。当归二钱五分。\",\n    \"components\": [\n      {\n        \"text_name\": \"黄\",\n        \"text_count\": \"一两\"\n      },\n      {\n        \"text_name\": \"当归\",\n        \"text_count\": \"二钱五分\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"血虚阳浮发热证。肌热面赤，烦渴欲饮，脉洪大而虚，重按无力。亦治妇人经期、产后血虚发热头痛；或疮疡溃后，久不愈合者。 本方可用于妇人经期、产后发热等属血虚阳浮者，以及各种贫血、过敏性紫癜等属血虚气弱者。\",\n    \"text_value\": \"血虚身热有奇方。\"\n  }\n]"