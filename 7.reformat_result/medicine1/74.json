"```json\n[\n  {\n    \"key\": \"name\",\n    \"value\": \"温脾汤\",\n    \"text_value\": \"千金翼温脾汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"大黄15克，当归9克，干姜9克，附子6克，人参6克，芒硝6克，甘草6克。\",\n    \"text_value\": \"干姜 大黄（各三两） 人参 附子（炮） 甘草（炙各二两）\",\n    \"components\": [\n      {\n        \"text_name\": \"干姜\",\n        \"text_count\": \"三两\"\n      },\n      {\n        \"text_name\": \"大黄\",\n        \"text_count\": \"三两\"\n      },\n      {\n        \"text_name\": \"人参\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"附子（炮）\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"甘草（炙）\",\n        \"text_count\": \"二两\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"脾阳不足，冷积便秘，或久利赤白，腹痛，手足不温，脉沉弦。阳虚寒积证，腹痛便秘，脐下绞结，绕脐不止，手足不温，苔白不渴，脉沉弦而迟。 本方常用于急性单纯性肠梗阻或不全梗阻等属中阳虚寒，冷积内阻者。\",\n    \"text_value\": \"主脾气不足。虚弱下痢。上入下出方。\"\n  }\n]\n```"