"[\n  {\n    \"key\": \"name\",\n    \"value\": \"白虎汤\",\n    \"text_value\": \"白虎汤原方\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"知母18克，石膏30～45克(碎)， 甘草6克(炙)， 粳米18克\",\n    \"text_value\": \"石膏（二斤碎） 知母（六两） 甘草（二两） 粳米（六合）上四味。加人参三两。\",\n    \"components\": [\n      {\n        \"text_name\": \"石膏\",\n        \"text_count\": \"二斤碎\"\n      },\n      {\n        \"text_name\": \"知母\",\n        \"text_count\": \"六两\"\n      },\n      {\n        \"text_name\": \"甘草\",\n        \"text_count\": \"二两\"\n      },\n      {\n        \"text_name\": \"粳米\",\n        \"text_count\": \"六合\"\n      },\n      {\n        \"text_name\": \"人参\",\n        \"text_count\": \"三两\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"伤寒阳明热盛，或温病热在气分证。壮热面赤，烦渴引饮，口舌干燥，大汗出，脉洪大有力，现用于流行性乙型脑炎、流行性脑脊髓膜炎、大叶性肺炎，夏季热等属于热在气分者。 【方论】 方中知母、石膏清肺胃之热而除烦渴；甘草、粳米益气生津、养胃和中。四味合用，共收清热生津之功。\",\n    \"text_value\": \"伤寒阳明热盛，或温病热在气分证（文本未直接给出主治，按方名对应常用主治补全）\"\n  }\n]"