"[\n  {\n    \"key\": \"name\",\n    \"value\": \"参苏饮\",\n    \"text_value\": \"参苏饮\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"木香15克 紫苏叶 干葛(洗) 半夏(汤洗七次，姜汁制，炒) 前胡(去苗) 人参 茯苓(去皮)各23克 枳壳(去瓤，麸炒) 桔梗(去芦) 甘草(炙) 陈皮(去白)各15克\",\n    \"text_value\": \"〔人参、紫苏、前胡、半夏（姜制）、干葛、茯苓各七钱半，陈皮、枳壳（麸炒）、桔梗、木香、甘草各二钱，每服二钱，加姜、枣煎。〕\",\n    \"components\": [\n      {\n        \"text_name\": \"人参\",\n        \"text_count\": \"七钱半\"\n      },\n      {\n        \"text_name\": \"紫苏\",\n        \"text_count\": \"七钱半\"\n      },\n      {\n        \"text_name\": \"前胡\",\n        \"text_count\": \"七钱半\"\n      },\n      {\n        \"text_name\": \"半夏（姜制）\",\n        \"text_count\": \"七钱半\"\n      },\n      {\n        \"text_name\": \"干葛\",\n        \"text_count\": \"七钱半\"\n      },\n      {\n        \"text_name\": \"茯苓\",\n        \"text_count\": \"七钱半\"\n      },\n      {\n        \"text_name\": \"陈皮\",\n        \"text_count\": \"二钱\"\n      },\n      {\n        \"text_name\": \"枳壳（麸炒）\",\n        \"text_count\": \"二钱\"\n      },\n      {\n        \"text_name\": \"桔梗\",\n        \"text_count\": \"二钱\"\n      },\n      {\n        \"text_name\": \"木香\",\n        \"text_count\": \"二钱\"\n      },\n      {\n        \"text_name\": \"甘草\",\n        \"text_count\": \"二钱\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"虚人外感风寒，内伤痰饮，恶寒发热，头痛鼻塞，咳嗽痰多，胸膈满闷，或痰积中脘，眩晕嘈杂，怔忡哕逆。\",\n    \"text_value\": \"治外感内伤，发热头痛，呕逆咳嗽，痰眩风泻。下虚上盛痰嗽喘。\"\n  }\n]"