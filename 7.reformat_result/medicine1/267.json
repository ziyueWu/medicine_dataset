"[\n  {\n    \"key\": \"name\",\n    \"value\": \"生脉散\",\n    \"text_value\": \"生脉\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"人参9克，麦门冬9克，五味子6克。\",\n    \"text_value\": \"人参五分。麦冬八分。五味子九分。\",\n    \"components\": [\n      {\n        \"text_name\": \"人参\",\n        \"text_count\": \"五分\"\n      },\n      {\n        \"text_name\": \"麦冬\",\n        \"text_count\": \"八分\"\n      },\n      {\n        \"text_name\": \"五味子\",\n        \"text_count\": \"九分\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"1.温热、暑热，耗气伤阴证。汗多神疲，体倦乏力，气短懒言，咽干口渴，舌干红少苦，脉虚数。\\n2.久咳伤肺，气阴两虚证。干咳少痰，短气自汗，口干舌燥，脉虚细。\",\n    \"text_value\": \"暑热刑金脉不支。若认脉虚通共剂。\"\n  }\n]"