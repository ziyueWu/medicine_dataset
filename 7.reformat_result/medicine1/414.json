"```json\n[\n  {\n    \"key\": \"name\",\n    \"value\": \"厚朴温中汤\",\n    \"text_value\": \"（汤）陈草苓，干姜草蔻木香停。\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"厚朴姜制、陈皮去白，各30g，炙甘草、茯苓去皮、草豆蔻仁、木香各15g，干姜2g。\",\n    \"text_value\": \"（浓朴、陈皮各一钱，甘草、茯苓、草豆蔻、木香各五分，干姜三分，加姜煎。）\",\n    \"components\": [\n      {\n        \"text_name\": \"浓朴\",\n        \"text_count\": \"一钱\"\n      },\n      {\n        \"text_name\": \"陈皮\",\n        \"text_count\": \"一钱\"\n      },\n      {\n        \"text_name\": \"甘草\",\n        \"text_count\": \"五分\"\n      },\n      {\n        \"text_name\": \"茯苓\",\n        \"text_count\": \"五分\"\n      },\n      {\n        \"text_name\": \"草豆蔻\",\n        \"text_count\": \"五分\"\n      },\n      {\n        \"text_name\": \"木香\",\n        \"text_count\": \"五分\"\n      },\n      {\n        \"text_name\": \"干姜\",\n        \"text_count\": \"三分\"\n      },\n      {\n        \"text_name\": \"姜\",\n        \"text_count\": \"加姜\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"寒湿气滞证。脘腹胀满或疼痛，不思饮食，舌苔白腻，脉沉弦。\",\n    \"text_value\": \"煎服加姜治腹痛，虚寒胀满用皆灵。治疮疡变寒内陷，心痞便溏，呃逆昏。寒散气行，痛胀自已矣。\"\n  }\n]\n```"