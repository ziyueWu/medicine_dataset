"[\n  {\n    \"key\": \"name\",\n    \"value\": \"小青龙汤\",\n    \"text_value\": \"小青龙汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"麻黄去节9g　芍药9g　细辛6g　干姜6g　甘草炙6g　桂枝去皮9g　半夏9g　五味子6g \",\n    \"text_value\": \"麻黄6g 生白芍9g 细辛3 炙甘草6g 桂枝9g 半夏9g 五味子6g 干姜6g\",\n    \"components\": [\n      {\n        \"text_name\": \"麻黄\",\n        \"text_count\": \"6g\"\n      },\n      {\n        \"text_name\": \"生白芍\",\n        \"text_count\": \"9g\"\n      },\n      {\n        \"text_name\": \"细辛\",\n        \"text_count\": \"3g\"\n      },\n      {\n        \"text_name\": \"炙甘草\",\n        \"text_count\": \"6g\"\n      },\n      {\n        \"text_name\": \"桂枝\",\n        \"text_count\": \"9g\"\n      },\n      {\n        \"text_name\": \"半夏\",\n        \"text_count\": \"9g\"\n      },\n      {\n        \"text_name\": \"五味子\",\n        \"text_count\": \"6g\"\n      },\n      {\n        \"text_name\": \"干姜\",\n        \"text_count\": \"6g\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"外寒内饮证。恶寒发热，无汗此为必备症状，胸痞喘咳，痰多而稀；或痰饮喘咳，不得平卧；或身体痛重，头面四肢浮肿（后三者为内饮的症候），舌苔白滑，脉浮者。\",\n    \"text_value\": \"外感风寒，内停水饮。症见恶寒发热不渴，无汗，浮肿、身体疼重、胸痞、干呕、咳喘、脉浮等。\"\n  }\n]"