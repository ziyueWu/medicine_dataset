"[\n  {\n    \"key\": \"name\",\n    \"value\": \"保元汤\",\n    \"text_value\": \"保元\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"桂枝6克 白术 人参各3克 黄芪2.5克 当归2.5克 生附子2克\",\n    \"text_value\": \"参 桂草四般存。（黄三钱。人参一钱。甘草一钱。肉桂春夏二分。）\",\n    \"components\": [\n      {\n        \"text_name\": \"黄\",\n        \"text_count\": \"三钱\"\n      },\n      {\n        \"text_name\": \"人参\",\n        \"text_count\": \"一钱\"\n      },\n      {\n        \"text_name\": \"甘草\",\n        \"text_count\": \"一钱\"\n      },\n      {\n        \"text_name\": \"肉桂\",\n        \"text_count\": \"春夏二分\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"主中风虚脱，卒然昏迷，不省人事，半身不遂。肾气易动而燥者，加芍药、地黄。\",\n    \"text_value\": \"补养诸汤首保元。柯韵伯曰。保元者保守其元气之谓也。\"\n  }\n]"