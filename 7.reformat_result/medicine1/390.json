"[\n  {\n    \"key\": \"name\",\n    \"value\": \"定志丸\",\n    \"text_value\": \"不加茯神为定志丸\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"菖蒲 远志（去心） 茯苓各15克 人参120克\",\n    \"text_value\": \"二分合少菖蒲 远志（去心） 茯苓（各二分） 人参（三两）上四味捣下筛\",\n    \"components\": [\n      {\n        \"text_name\": \"菖蒲\",\n        \"text_count\": \"少\"\n      },\n      {\n        \"text_name\": \"远志（去心）\",\n        \"text_count\": \"二分\"\n      },\n      {\n        \"text_name\": \"茯苓\",\n        \"text_count\": \"二分\"\n      },\n      {\n        \"text_name\": \"人参\",\n        \"text_count\": \"三两\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"主治心神虚怯，五脏不足，神思不安，甚则悲忧不乐，或善忘惊悸；或喜笑不休，语言无伦，朝轻暮重，或暮愈朝发。\",\n    \"text_value\": \"朝瘥暮剧。暮瘥朝发。发则狂眩。\"\n  }\n]"