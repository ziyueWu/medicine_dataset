"[\n  {\n    \"key\": \"name\",\n    \"value\": \"炙甘草汤\",\n    \"text_value\": \"炙甘草汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"炙甘草（12克） 生姜（9克） 桂枝（9克） 人参（6克） 生地黄（30克） 阿胶（6克） 麦门冬（10克） 麻仁（10克） 大枣（10枚）\",\n    \"text_value\": \"甘草 生姜 人参 生地 桂枝 麦冬 阿胶 麻仁 大枣（一名复脉汤）\",\n    \"components\": [\n      {\n        \"text_name\": \"甘草\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"生姜\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"人参\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"生地\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"桂枝\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"麦冬\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"阿胶\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"麻仁\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"大枣\",\n        \"text_count\": \"\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"1．阴血不足，阳气虚弱证。脉结代，心动悸，虚羸少气，舌光少苔，或质干而瘦小者。\\n2．虚劳肺症。干咳无痰，或咳吐涎沫，量少，形瘦短气，虚烦不眠，自汗盗汗，咽干舌燥，大便干结，脉虚数。 本方常用于功能性心律不齐、期外收缩、冠心病、风湿性心脏病、病毒性心肌炎、甲状腺功能亢进等而有心悸气短、脉结代等属阴血不足，阳气虚弱者。）\",\n    \"text_value\": \"脉结代，心动悸，此汤主之（脉结代者，血气虚衰）。\"\n  }\n]"