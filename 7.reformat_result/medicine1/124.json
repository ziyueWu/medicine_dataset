"[\n  {\n    \"key\": \"name\",\n    \"value\": \"白虎加苍术汤\",\n    \"text_value\": \"白虎加苍术汤\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"知母18g，石膏50g，甘草炙6g，粳米9g，苍术9g。\",\n    \"text_value\": \"本方由石膏、知母、甘草、粳米、苍术五药而组成。（并提及《医宗金鉴》又加茯苓）\",\n    \"components\": [\n      {\n        \"text_name\": \"石膏\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"知母\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"甘草\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"粳米\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"苍术\",\n        \"text_count\": \"\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"湿温病。身热胸痞，汗多，舌红苔白腻等。以及风湿热痹，症见身大热，关节肿痛等。\",\n    \"text_value\": \"这个方子是治疗湿温病的。其证是身重、胸满、头疼、妄言、多汗、两胫逆冷等。\"\n  }\n]"