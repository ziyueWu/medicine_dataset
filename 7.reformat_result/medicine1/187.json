"[\n  {\n    \"key\": \"name\",\n    \"value\": \"清胃散\",\n    \"text_value\": \"清胃散\"\n  },\n  {\n    \"key\": \"component\",\n    \"value\": \"生地黄（6克）当归身（6克）牡丹皮（9克）黄连（6克）升麻（9克）\",\n    \"text_value\": \"清胃散生地 丹皮 黄连 当归 升麻\",\n    \"components\": [\n      {\n        \"text_name\": \"生地\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"丹皮\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"黄连\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"当归\",\n        \"text_count\": \"\"\n      },\n      {\n        \"text_name\": \"升麻\",\n        \"text_count\": \"\"\n      }\n    ]\n  },\n  {\n    \"key\": \"cure\",\n    \"value\": \"胃火牙痛。牙痛牵引头疼，面颊发热，其齿喜冷恶热，或牙宣出血，或牙龈红肿溃烂，或唇舌腮颊肿痛，口气热臭，口干舌燥，舌红苔黄，脉滑数。本方常用于口腔炎、牙周炎、三叉神经痛等属胃火上攻者。\",\n    \"text_value\": \"凉血解热，升阳散火。胃气清，则诸病自除矣。\"\n  }\n]"